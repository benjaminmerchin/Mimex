{
  "name": "mimex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "pnpm db:generate && tsc -b && vite build && pnpm build:server",
    "build:server": "tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "lint": "oxlint",
    "preview": "vite preview",
    "fetch-ffmpeg": "mkdir -p vendor && curl -sL https://github.com/eugeneware/ffmpeg-static/releases/download/b6.1.1/ffmpeg-linux-x64 -o vendor/ffmpeg-linux-x64 && chmod +x vendor/ffmpeg-linux-x64"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@hono/node-server": "^2.0.10",
    "@netlify/blobs": "^10.7.9",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/vite": "^4.3.3",
    "better-auth": "1.6.9",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.3.0",
    "hono": "^4.12.31",
    "lucide-react": "^1.25.0",
    "motion": "^12.42.2",
    "prisma": "^6.19.3",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.2.0",
    "resend": "6.12.2",
    "shadcn": "^4.13.1",
    "stripe": "^22.3.2",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
